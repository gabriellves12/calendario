# ───────────────────────────────────────────────────────────────
# Nevel MED · variáveis de ambiente
# Copie para ".env" (local) e configure também no painel da Vercel
# (Settings → Environment Variables). NUNCA comite o .env real.
# ───────────────────────────────────────────────────────────────

# ── Login do time (autenticação simples do painel) ──
TEAM_USER=nevel2026
TEAM_PASS=marketing
# Segredo usado para assinar o token de sessão. Gere um valor longo e aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-longo-e-aleatorio

# ── App da Meta (Instagram Graph API) ──
# Crie em https://developers.facebook.com  → produtos: Facebook Login + Instagram Graph API
META_APP_ID=
META_APP_SECRET=
# URL pública do callback OAuth (precisa bater EXATAMENTE com a cadastrada na Meta):
#   ex.: https://seu-projeto.vercel.app/api/instagram/callback
META_REDIRECT_URI=

# Versão da Graph API
GRAPH_API_VERSION=v21.0

# ── Vercel KV (armazenamento do token do Instagram e dos posts) ──
# Criado automaticamente ao adicionar um KV Store no projeto Vercel.
# Storage → Create → KV. As variáveis abaixo são injetadas pela Vercel:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
